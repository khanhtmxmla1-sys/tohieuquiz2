{
  "rewrites": [
    { "source": "/api/cliproxy/:path*", "destination": "https://api.thitong.site/v1/:path*" },
    { "source": "/api/deepseek/:path*", "destination": "https://api.deepseek.com/:path*" },
    { "source": "/((?!api/|assets/|.*\\..*).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
