        },
        "quiz_player": {
            "pattern": "Feature-based (Modular Hook & Sub-components)",
            "directory": "src/features/quiz-player/",
            "logic": {
                "hook": "useQuizPlayer.ts",
                "scoring": "utils/quizScoring.ts"
            },
            "sub_components": [
                { "name": "QuizHeader", "desc": "Timer, ProgressBar, Title" },
                { "name": "QuizNavigation", "desc": "Question Map Grid / Question Bank" },
                { "name": "QuizPagination", "desc": "Page controls & Submission trigger" }
            ],
            "optimization": "React.memo for QuestionRenderer"
        },
        "quiz_editor": {
            "pattern": "Feature-based (Smart Hook & Draft Mapping)",
            "directory": "src/features/quiz-editor/",
            "logic": {
                "hook": "useQuestionEditor.ts",
                "mapper": "utils/questionDraftMapper.ts",
                "ai_service": "hooks/useSmartDistractors.ts"
            },
            "sub_components": [
                { "name": "QuestionCard", "desc": "Smart Preview/Actions card" },
                { "name": "QuestionEditorModal", "desc": "Dispatcher for 14+ type-specific editors" }
            ],
            "strict_mode": "Zero Build Errors policy"
        }
    },
