# =====================================================
# ITONG QUIZ - Environment Configuration
# =====================================================
# Copy this file to .env.local and fill in your values
# =====================================================

# Google Apps Script URL (bắt buộc để kết nối Google Sheets)
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# API Secret Token cho Google Sheets
VITE_API_SECRET_TOKEN=

# =====================================================
# AI API Keys (chọn 1 hoặc nhiều providers)
# =====================================================

# Google Gemini
VITE_GEMINI_API_KEY=

# Perplexity AI
VITE_PERPLEXITY_API_KEY=

# OpenAI
VITE_OPENAI_API_KEY=
# VITE_OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek
VITE_DEEPSEEK_API_KEY=

# =====================================================
# LLM-Mux / AIClient-2-API (local proxy)
# =====================================================
VITE_LLM_MUX_BASE_URL=https://api.thitong.site/v1
VITE_LLM_MUX_API_KEY=sk-khanh20111989tom@
