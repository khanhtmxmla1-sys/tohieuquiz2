# =====================================================
# ITONG QUIZ - Environment Configuration
# =====================================================
# Copy this file to .env.local and fill in your values
# =====================================================

# Google Apps Script URL (bắt buộc để kết nối Google Sheets)
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/AKfycbysG-FqfJc78vX7H0-tQyO1QigH9X_7aTntuGk3-p1qDkP5eC1YtDq72sYI_87fR_G-/exec

# Database Environment Variable (true = Cloudflare D1, false = Google Sheets)
VITE_USE_D1=true

# API Endpoints
VITE_WORKERS_API_URL=https://itongquiz-api.tongminhkhanh.workers.dev

# Security Token (MUST MATCH WORKERS wrangler.toml AND GOOGLE APPS SCRIPT)
VITE_API_SECRET_TOKEN=your_secret_token_here

# =====================================================
# Feature flags
# =====================================================
# Gift Shop V2 rollout flag (false = hidden, true = enabled)
VITE_FEATURE_GIFT_SHOP_V2=false

# Gift Shop data mode
# - mock: local mock state for phase 1/internal testing
# - api: call backend endpoints for phase 2
VITE_GIFT_SHOP_MODE=api

# =====================================================
# Sitemap generator (build-time only, server-side)
# =====================================================
# Base site URL used in sitemap <loc>
SITEMAP_SITE_URL=https://www.thitong.site
# Workers API URL for fetching quizzes (optional if VITE_WORKERS_API_URL already set)
SITEMAP_API_URL=
# Server-side API token used only by build script (recommended, do NOT expose to client)
SITEMAP_API_TOKEN=

# =====================================================
# AI API Keys (chọn 1 hoặc nhiều providers)
# =====================================================

# Google Gemini
VITE_GEMINI_API_KEY=

# Perplexity AI
VITE_PERPLEXITY_API_KEY=

# OpenAI
VITE_OPENAI_API_KEY=
# VITE_OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek
VITE_DEEPSEEK_API_KEY=

# =====================================================
# LLM-Mux / AIClient-2-API (local proxy)
# =====================================================
VITE_LLM_MUX_BASE_URL=https://api.thitong.site/v1
VITE_LLM_MUX_API_KEY=your_llm_mux_key_here
